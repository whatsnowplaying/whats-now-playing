   <item>
    <layout class="QHBoxLayout" name="filepattern_layout">
     <item>
      <widget class="QLabel" name="filepattern_label">
       <property name="text">
        <string>File Pattern</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QLineEdit" name="filepattern_lineedit">
       <property name="toolTip">
        <string>Filename pattern using strftime format. Examples: setlist-%Y%m%d.txt, show-%Y%m%d-%H%M%S.txt</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QTextBrowser" name="help_label">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="html">
      <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body&gt;
&lt;p&gt;&lt;span style=&quot;font-weight:600;&quot;&gt;File Pattern Help&lt;/span&gt; — uses strftime format codes:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;%Y = 4-digit year&lt;/li&gt;
&lt;li&gt;%m = month (01–12)&lt;/li&gt;
&lt;li&gt;%d = day (01–31)&lt;/li&gt;
&lt;li&gt;%H = hour (00–23)&lt;/li&gt;
&lt;li&gt;%M = minute (00–59)&lt;/li&gt;
&lt;li&gt;%S = second (00–59)&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;span style=&quot;font-weight:600;&quot;&gt;Examples:&lt;/span&gt; setlist-%Y%m%d.txt → setlist-20231215.txt&lt;br/&gt;show-%Y%m%d-%H%M%S.txt → show-20231215-143022.txt&lt;/p&gt;
&lt;p&gt;Files are saved to the &lt;span style=&quot;font-weight:600;&quot;&gt;WhatsNowPlaying/setlists&lt;/span&gt; directory.&lt;/p&gt;
&lt;/body&gt;&lt;/html&gt;</string>
     </property>
    </widget>
   </item>
   <item>
    <widget class="QTextBrowser" name="description_label">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
       <horstretch>0</horstretch>
       <verstretch>1</verstretch>
      </sizepolicy>
     </property>
     <property name="html">
      <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body&gt;
&lt;p&gt;Real-time setlist appends each track to a file as it plays, using your custom template.&lt;/p&gt;
&lt;p&gt;Unlike the traditional setlist (generated at the end of a session), this creates a live setlist during your session. Perfect for streaming or live events where you want real-time updates.&lt;/p&gt;
&lt;/body&gt;&lt;/html&gt;</string>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
