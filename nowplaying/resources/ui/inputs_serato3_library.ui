<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>inputs_serato3_library_ui</class>
 <widget class="QWidget" name="inputs_serato3_library_ui">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>640</width>
    <height>480</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Library and Query</string>
  </property>
  <layout class="QVBoxLayout" name="main_layout">
   <property name="margin">
    <number>10</number>
   </property>
   <property name="spacing">
    <number>10</number>
   </property>
   <item>
    <widget class="QGroupBox" name="artist_query_groupbox">
     <property name="title">
      <string>Artist Query Configuration</string>
     </property>
     <layout class="QVBoxLayout" name="artist_query_box_layout">
      <item>
       <layout class="QHBoxLayout" name="scope_layout">
        <item>
         <widget class="QLabel" name="artist_query_label">
          <property name="enabled">
           <bool>true</bool>
          </property>
          <property name="font">
           <font>
            <bold>true</bold>
           </font>
          </property>
          <property name="text">
           <string>Artist Query Scope</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QComboBox" name="serato_artist_scope_combo">
          <property name="enabled">
           <bool>true</bool>
          </property>
          <item>
           <property name="text">
            <string>Entire Library</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>Selected Playlists</string>
           </property>
          </item>
         </widget>
        </item>
        <item>
         <widget class="QLineEdit" name="serato_playlists_lineedit">
          <property name="enabled">
           <bool>true</bool>
          </property>
          <property name="placeholderText">
           <string>Comma-separated crate names (e.g., House, Techno)</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QTextBrowser" name="query_help_label">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
         </sizepolicy>
        </property>
        <property name="html">
         <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body&gt;
&lt;p&gt;Configure how artist queries from Twitch chat (!hasartist command) search your music library.&lt;/p&gt;
&lt;p&gt;Choose &lt;span style=&quot;font-weight:600;&quot;&gt;Entire Library&lt;/span&gt; to search all tracks, or &lt;span style=&quot;font-weight:600;&quot;&gt;Selected Playlists&lt;/span&gt; to limit searches to specific crates.&lt;/p&gt;
&lt;/body&gt;&lt;/html&gt;</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="additional_libs_groupbox">
     <property name="title">
      <string>Additional Library Paths</string>
     </property>
     <layout class="QVBoxLayout" name="additional_libs_box_layout">
      <item>
       <layout class="QHBoxLayout" name="additional_libs_row">
        <item>
         <widget class="QTextEdit" name="additional_libs_textedit">
          <property name="toolTip">
           <string>Additional Serato library paths (one per line). Used for external drives and multiple music collections.</string>
          </property>
         </widget>
        </item>
        <item>
         <layout class="QVBoxLayout" name="libs_button_layout">
          <item>
           <widget class="QPushButton" name="add_additional_lib_button">
            <property name="text">
             <string>Add Path...</string>
            </property>
            <property name="toolTip">
             <string>Browse for additional Serato library directory</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer>
            <property name="orientation">
             <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>20</width>
              <height>40</height>
             </size>
            </property>
           </spacer>
          </item>
         </layout>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QTextBrowser" name="additional_libs_help_label">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
         </sizepolicy>
        </property>
        <property name="html">
         <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body&gt;
&lt;p&gt;Enter additional &lt;span style=&quot;font-style:italic;&quot;&gt;_Serato_&lt;/span&gt; folder paths (one per line) for external drives or multiple libraries.&lt;/p&gt;
&lt;/body&gt;&lt;/html&gt;</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <spacer>
     <property name="orientation">
      <enum>Qt::Vertical</enum>
     </property>
     <property name="sizeHint" stdset="0">
      <size>
       <width>20</width>
       <height>40</height>
      </size>
     </property>
    </spacer>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections>
  <connection>
   <sender>local_button</sender>
   <signal>toggled(bool)</signal>
   <receiver>artist_query_label</receiver>
   <slot>setEnabled(bool)</slot>
  </connection>
  <connection>
   <sender>local_button</sender>
   <signal>toggled(bool)</signal>
   <receiver>serato_artist_scope_combo</receiver>
   <slot>setEnabled(bool)</slot>
  </connection>
  <connection>
   <sender>local_button</sender>
   <signal>toggled(bool)</signal>
   <receiver>serato_playlists_lineedit</receiver>
   <slot>setEnabled(bool)</slot>
  </connection>
  <connection>
   <sender>local_button</sender>
   <signal>toggled(bool)</signal>
   <receiver>query_help_label</receiver>
   <slot>setEnabled(bool)</slot>
  </connection>
 </connections>
</ui>
