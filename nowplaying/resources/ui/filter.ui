      <number>0</number>
     </property>
     <widget class="QWidget" name="simple_tab">
      <attribute name="title">
       <string>Simple</string>
      </attribute>
      <layout class="QVBoxLayout" name="simple_tab_layout">
       <item>
        <widget class="QLabel" name="phrases_label">
         <property name="text">
          <string>Select phrases and formats to filter:</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QTableWidget" name="phrases_table">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
           <horstretch>0</horstretch>
           <verstretch>1</verstretch>
          </sizepolicy>
         </property>
         <property name="alternatingRowColors">
          <bool>true</bool>
         </property>
         <property name="selectionBehavior">
          <enum>QAbstractItemView::SelectRows</enum>
         </property>
         <property name="sortingEnabled">
          <bool>false</bool>
         </property>
         <column>
          <property name="text">
